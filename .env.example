# ---------------------------------------------------------------------------
# Für die lokale Entwicklung: als .env.local kopieren.
# Für Docker Compose: als .env kopieren (Compose liest .env automatisch).
# ---------------------------------------------------------------------------

# Basis-URL des Code-Runners (Piston), ohne abschließenden Slash.
# Nicht gesetzt = alles läuft normal, nur die C#-Übungen zeigen einen Hinweis.
#
# In docker-compose.yml ist der Wert bereits auf den internen Service gesetzt;
# diese Zeile brauchst du nur für die Entwicklung ohne Compose.
CODE_RUNNER_URL=http://localhost:2000

# Host-Port des Webservers, falls 3000 bei dir schon belegt ist.
# Wird nur von docker-compose.yml ausgewertet.
WEB_PORT=3000
