# Einheitliche Zeilenenden - das Repo wird auf Windows entwickelt und auf Linux
# gehostet. Im Repository steht immer LF.
* text=auto eol=lf

# Windows-Skripte brauchen CRLF, sonst stolpert cmd.exe darüber.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binärdateien nie anfassen.
*.png binary
*.jpg binary
*.ico binary
*.wasm binary
